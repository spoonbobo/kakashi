# Use official Node.js image
FROM node:23.7-alpine

# Set working directory
WORKDIR /app

# Copy package.json and package-lock.json
COPY package*.json ./

RUN npm install 

# Copy the chat server source code
COPY src/server /app/src/server/

# Expose the port the chat server runs on
EXPOSE 3001

# Start the chat server directly with Node
# This bypasses the TypeScript compilation issue
CMD ["node", "src/server/chat_server.ts"]